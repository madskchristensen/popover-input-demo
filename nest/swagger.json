{
  "openapi": "3.0.0",
  "paths": {
    "/job-category": {
      "get": {
        "operationId": "JobCategoryController_findAll",
        "parameters": [
          {
            "name": "search",
            "required": false,
            "in": "query",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/JobCategory"
                  }
                }
              }
            }
          }
        },
        "tags": [
          "JobCategory"
        ]
      }
    },
    "/job-role": {
      "get": {
        "operationId": "JobRoleController_findAll",
        "parameters": [
          {
            "name": "jobCategoryId",
            "required": false,
            "in": "query",
            "schema": {
              "format": "uuid",
              "type": "string"
            }
          },
          {
            "name": "search",
            "required": false,
            "in": "query",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/JobRole"
                  }
                }
              }
            }
          }
        },
        "tags": [
          "JobRole"
        ]
      }
    },
    "/job-application": {
      "get": {
        "operationId": "JobApplicationController_findAll",
        "parameters": [
          {
            "name": "search",
            "required": false,
            "in": "query",
            "schema": {
              "type": "array",
              "items": {
                "$ref": "#/components/schemas/SearchDto",
                "type": "object"
              }
            }
          },
          {
            "name": "sorting",
            "required": false,
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "limit",
            "required": true,
            "in": "query",
            "schema": {
              "minimum": 1,
              "default": 20,
              "type": "number"
            }
          },
          {
            "name": "page",
            "required": true,
            "in": "query",
            "schema": {
              "minimum": 1,
              "default": 1,
              "type": "number"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "The paginated result of JobApplication",
            "content": {
              "application/json": {
                "schema": {
                  "title": "PaginatedResponseOfJobApplication",
                  "allOf": [
                    {
                      "$ref": "#/components/schemas/PageDto"
                    },
                    {
                      "properties": {
                        "data": {
                          "type": "array",
                          "items": {
                            "$ref": "#/components/schemas/JobApplication"
                          }
                        }
                      }
                    }
                  ]
                }
              }
            }
          }
        },
        "tags": [
          "JobApplication"
        ]
      }
    }
  },
  "info": {
    "title": "Job Applications API",
    "description": "API for managing job applications",
    "version": "1.0",
    "contact": {}
  },
  "tags": [],
  "servers": [],
  "components": {
    "schemas": {
      "JobCategory": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "code": {
            "type": "string"
          },
          "roles": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/JobRole"
            }
          },
          "id": {
            "type": "string"
          }
        },
        "required": [
          "name",
          "code",
          "roles",
          "id"
        ]
      },
      "JobApplication": {
        "type": "object",
        "properties": {
          "firstName": {
            "type": "string"
          },
          "lastName": {
            "type": "string"
          },
          "email": {
            "type": "string"
          },
          "country": {
            "type": "string"
          },
          "status": {
            "enum": [
              "NEW",
              "PENDING_REVIEW",
              "IN_REVIEW",
              "REVIEWED",
              "SHORTLISTED",
              "REJECTED"
            ],
            "type": "string"
          },
          "jobRoleId": {
            "type": "string"
          },
          "jobRole": {
            "$ref": "#/components/schemas/JobRole"
          },
          "createdAt": {
            "format": "date-time",
            "type": "string"
          },
          "updatedAt": {
            "format": "date-time",
            "type": "string"
          },
          "id": {
            "type": "string"
          }
        },
        "required": [
          "firstName",
          "lastName",
          "email",
          "country",
          "status",
          "jobRoleId",
          "jobRole",
          "createdAt",
          "updatedAt",
          "id"
        ]
      },
      "JobRole": {
        "type": "object",
        "properties": {
          "title": {
            "type": "string"
          },
          "jobCategoryId": {
            "type": "string"
          },
          "jobCategory": {
            "$ref": "#/components/schemas/JobCategory"
          },
          "applications": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/JobApplication"
            }
          },
          "id": {
            "type": "string"
          }
        },
        "required": [
          "title",
          "jobCategoryId",
          "jobCategory",
          "applications",
          "id"
        ]
      },
      "PageDtoPagination": {
        "type": "object",
        "properties": {
          "currentPage": {
            "type": "number",
            "readOnly": true
          },
          "nextPage": {
            "type": "number",
            "readOnly": true
          },
          "prevPage": {
            "type": "number",
            "readOnly": true
          },
          "found": {
            "type": "number",
            "readOnly": true
          },
          "totalFound": {
            "type": "number",
            "readOnly": true
          },
          "totalPages": {
            "type": "number",
            "readOnly": true
          }
        },
        "required": [
          "currentPage",
          "found",
          "totalFound",
          "totalPages"
        ]
      },
      "PageDto": {
        "type": "object",
        "properties": {
          "data": {
            "readOnly": true,
            "type": "array",
            "items": {
              "type": "object"
            }
          },
          "pagination": {
            "readOnly": true,
            "allOf": [
              {
                "$ref": "#/components/schemas/PageDtoPagination"
              }
            ]
          }
        },
        "required": [
          "data",
          "pagination"
        ]
      },
      "SearchPayload": {
        "type": "object",
        "properties": {
          "value": {
            "type": "string"
          },
          "exact": {
            "type": "boolean"
          }
        },
        "required": [
          "value",
          "exact"
        ]
      },
      "SearchColumnDto": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "payload": {
            "$ref": "#/components/schemas/SearchPayload"
          }
        },
        "required": [
          "name",
          "payload"
        ]
      },
      "SearchDto": {
        "type": "object",
        "properties": {
          "table": {
            "type": "string"
          },
          "columns": {
            "minItems": 1,
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/SearchColumnDto"
            }
          }
        },
        "required": [
          "table",
          "columns"
        ]
      }
    }
  }
}